---
import path from "node:path";

interface Props {
	id?: string;
	src: string;
	mobileSrc?: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
}

import { Image } from "astro:assets";
import { url } from "../../utils/url-utils";

const { id, src, alt, position = "center", basePath = "/", mobileSrc } = Astro.props;
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
// biome-ignore lint/suspicious/noImplicitAnyLet: <check later>
let img;
if (isLocal) {
	const files = import.meta.glob<ImageMetadata>("../../**", {
		import: "default",
	});
	let normalizedPath = path
		.normalize(path.join("../../", basePath, src))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (!file) {
		console.error(
			`\n[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
		);
	}
	img = await file();
}

// Mobile image handling
let mobileImg;
let mobileIsLocal = false;
let mobileIsPublic = false;
if (mobileSrc) {
	mobileIsLocal = !(
		mobileSrc.startsWith("/") ||
		mobileSrc.startsWith("http") ||
		mobileSrc.startsWith("https") ||
		mobileSrc.startsWith("data:")
	);
	mobileIsPublic = mobileSrc.startsWith("/");

	if (mobileIsLocal) {
		const files = import.meta.glob<ImageMetadata>("../../**", {
			import: "default",
		});
		let normalizedPath = path
			.normalize(path.join("../../", basePath, mobileSrc))
			.replace(/\\/g, "/");
		const file = files[normalizedPath];
		if (!file) {
			console.error(
				`\n[ERROR] Mobile image file not found: ${normalizedPath.replace("../../", "src/")}`,
			);
		}
		mobileImg = await file();
	}
}

const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;
---
<div id={id} class:list={[className, 'overflow-hidden relative']}>
    <div class="transition absolute inset-0 dark:bg-black/10 bg-opacity-50 pointer-events-none"></div>
    {isLocal && img && <Image src={img} alt={alt || ""} class:list={[imageClass, mobileSrc ? 'hidden md:block' : '']} style={imageStyle}/>}
    {!isLocal && <img src={isPublic ? url(src) : src} alt={alt || ""} class:list={[imageClass, mobileSrc ? 'hidden md:block' : '']} style={imageStyle}/>}
    {mobileSrc && mobileIsLocal && mobileImg && <Image src={mobileImg} alt={alt || ""} class:list={[imageClass, 'block md:hidden']} style={imageStyle}/>}
    {mobileSrc && !mobileIsLocal && <img src={mobileIsPublic ? url(mobileSrc) : mobileSrc} alt={alt || ""} class:list={[imageClass, 'block md:hidden']} style={imageStyle}/>}
</div>
